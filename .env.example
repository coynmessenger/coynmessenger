# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/coyn_messenger

# Thirdweb Configuration
# Get your free Client ID from: https://thirdweb.com/dashboard
VITE_THIRDWEB_CLIENT_ID=your_client_id_here

# Environment
NODE_ENV=production

# Security
SESSION_SECRET=your-secure-session-secret-here

# Blockchain APIs (Optional - will use fallback if not provided)
COINGECKO_API_KEY=your-coingecko-api-key
BSC_RPC_URL=https://bsc-dataseed1.binance.org/

# Amazon API (Optional - will use mock data if not provided)
AMAZON_ACCESS_KEY=your-amazon-access-key
AMAZON_SECRET_KEY=your-amazon-secret-key
AMAZON_ASSOCIATE_TAG=your-associate-tag

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,application/pdf

# WebRTC/Voice Call Configuration
WEBRTC_STUN_SERVER=stun:stun.l.google.com:19302
WEBRTC_TURN_SERVER=turn:your-turn-server.com:3478
TURN_USERNAME=your-turn-username
TURN_CREDENTIAL=your-turn-credential

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# CORS Configuration
ALLOWED_ORIGINS=https://your-domain.replit.app,https://your-custom-domain.com