efined","isPrimary":true}],"breadcrumb":{"topLevelId":"money_insurance","topLevelDisplayName":"Money \u0026 Insurance","midLevelId":"investments_wealth","midLevelDisplayName":"Investments \u0026 Wealth","bottomLevelId":"non_bank_finance","bottomLevelDisplayName":"Non-Bank Financial Service"},"isClaimed":true,"isClosed":false,"isTemporarilyClosed":false,"locationsCount":0,"isCollectingReviews":false,"verification":{"verifiedByGoogle":false,"verifiedPaymentMethod":false,"verifiedUserIdentity":false},"hasCollectedIncentivisedReviews":false,"consumerAlert":{"authorityWarningLink":null,"content":null,"languageVersions":null,"predefinedType":"InfoHighRiskInvestment","title":null,"titleLanguageVersions":null},"consumerAlerts":[{"authorityWarningLink":null,"content":null,"languageVersions":null,"predefinedType":"InfoHighRiskInvestment","title":null,"titleLanguageVersions":null}],"isMerged":false,"contactInfo":{"email":"inbox@zerion.io","address":"1412 Market Street","city":"San Francisco","country":"US","phone":"","zipCode":"94102"},"activity":{"isUsingPaidFeatures":false,"hasSubscription":false,"isAskingForReviews":false,"claimedDate":"2020-04-09T01:47:46.000Z","isClaimed":true,"previouslyClaimed":true,"replyBehavior":{"averageDaysToReply":0,"lastReplyToNegativeReview":null,"negativeReviewsWithRepliesCount":0,"replyPercentage":0,"totalNegativeReviewsCount":2},"verification":{"verifiedByGoogle":false,"verifiedPaymentMethod":false,"verifiedUserIdentity":false},"hasBusinessUnitMergeHistory":false,"basiclinkRate":0,"hideBasicLinkAlert":false,"isUsingAIResponses":false},"hasCustomHeaderSetting":false,"hasPromotionSetting":false},"reviews":[{"id":"68495aec4c86f11d6c360888","filtered":false,"pending":false,"text":"Professional and responsive team. Tawny Swift helped me every step of the way and returned my refund without delay. Excellent service overall.","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-06-11T12:31:08.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Professional and responsive","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-05-12T00:00:00.000Z","publishedDate":"2025-06-11T12:31:08.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"683c51e34e662d572a2cfc21","displayName":"Jeremy Bedley","imageUrl":"","numberOfReviews":1,"countryCode":"AU","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"en","location":null},{"id":"682df51a0c11e64b74bc0ff7","filtered":false,"pending":false,"text":"I PAID FOR CRYPTOS BUT IN DESPITE OF HOURS \u0026 HOURS ASKING + WAITING TO THEIR SUPPORT CHAT, I NEVER RECEIVED MY COINS PAID !!!\n\nTHINK TWICE BEFORE DEALING WITH THAT COMPANY !!\n\nTRANSACTION 0xc0fedd9d379c26704f0d3c5698b9c0b4aac54aae78e09e0178f70defa818dce5","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-05-21T17:45:30.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"I NEVER RECEIVED THE COINS PAID !!","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-05-13T00:00:00.000Z","publishedDate":"2025-05-21T17:45:30.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"5a5480580000ff000afd1836","displayName":"Luay","imageUrl":"","numberOfReviews":20,"countryCode":"UA","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"en","location":null},{"id":"676893869f6a8f90a5d50e1a","filtered":false,"pending":false,"text":"Zerion is the absolute best in web3, and the only crypto platform I feel safe getting my loved ones onto. Immaculately simple way to access the EVM L2-verse along with mainnet Ethereum needs, and with the launch of their own L2, super excited. \n\nWhat really makes Zerion special however = the people working on it. Without doxxing anyone, the support teams, the product and marketing teams, have all been incredible whether I have questions or issues or feedback. In app chat support especially shines. \n\nCan’t say enough good stuff about Zerion - the platform has honestly changed my life for the better, protected me from scams, and been a delight to use. ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2024-12-23T00:32:38.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Zerion is the absolute best of web3, built by the best people.","likes":0,"source":"Organic","dates":{"experiencedDate":"2024-12-22T00:00:00.000Z","publishedDate":"2024-12-23T00:32:38.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"659446228114f00012ffe641","displayName":"Grey Seymour","imageUrl":"","numberOfReviews":2,"countryCode":"US","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":2,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"en","location":null},{"id":"67643921a2e3320c5347d30c","filtered":false,"pending":false,"text":"top wallet for multi chain support. \nincredible professional help support too\n\nhighly recomend to start your coin/token experiance with them","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2024-12-19T17:17:53.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"top wallet for multi chain support","likes":0,"source":"Organic","dates":{"experiencedDate":"2024-12-19T00:00:00.000Z","publishedDate":"2024-12-19T17:17:53.000Z