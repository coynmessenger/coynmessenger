4bdd50","displayName":"Anas Rguig","imageUrl":"https://user-images.trustpilot.com/660ae133109d0c00124bdd50/73x73.png","numberOfReviews":1,"countryCode":"CA","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"en","location":null},{"id":"6606d50f40cbea0c3e091d08","filtered":false,"pending":false,"text":"introduced a new token and Nahuel from Zerion really helped get us going. Zerion is an amazing portfolio tracker (and more) but their customer service is excellent (something that just doesn't happen in crypto)","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2024-03-29T16:49:52.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"big time help setting up new token","likes":0,"source":"Organic","dates":{"experiencedDate":"2024-03-29T00:00:00.000Z","publishedDate":"2024-03-29T16:49:52.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6606d505825c8800129be2be","displayName":"Rick Alexander","imageUrl":"https://user-images.trustpilot.com/6606d505825c8800129be2be/73x73.png","numberOfReviews":1,"countryCode":"US","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"en","location":null},{"id":"660102c5575416d6517d0b53","filtered":false,"pending":false,"text":"a very bad option for people who use wallets to log in to sites. It simply wont work.","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2024-03-25T06:51:18.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"a very bad option for people who use…","likes":0,"source":"Organic","dates":{"experiencedDate":"2024-03-25T00:00:00.000Z","publishedDate":"2024-03-25T06:51:18.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"5830597e0000ff000a58e9f9","displayName":"Sean Vitun Groves","imageUrl":"","numberOfReviews":13,"countryCode":"GB","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"en","location":null},{"id":"65fdf11fc21aca2deced2560","filtered":false,"pending":false,"text":"Grate response, quick update and cordial conversation.","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2024-03-22T22:59:12.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Grate response","likes":0,"source":"Organic","dates":{"experiencedDate":"2024-03-21T00:00:00.000Z","publishedDate":"2024-03-22T22:59:12.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"64396bad2f180b0012fec91f","displayName":"Pedro Ivo Bruder","imageUrl":"https://user-images.trustpilot.com/64396bad2f180b0012fec91f/73x73.png","numberOfReviews":2,"countryCode":"BR","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":2,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"en","location":null}],"relevantReviews":[{"id":"676893869f6a8f90a5d50e1a","filtered":false,"pending":false,"text":"Zerion is the absolute best in web3, and the only crypto platform I feel safe getting my loved ones onto. Immaculately simple way to access the EVM L2-verse along with mainnet Ethereum needs, and with the launch of their own L2, super excited. \n\nWhat really makes Zerion special however = the people working on it. Without doxxing anyone, the support teams, the product and marketing teams, have all been incredible whether I have questions or issues or feedback. In app chat support especially shines. \n\nCan’t say enough good stuff about Zerion - the platform has honestly changed my life for the better, protected me from scams, and been a delight to use. ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2024-12-23T00:32:38.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Zerion is the absolute best of web3, built by the best people.","likes":0,"source":"Organic","dates":{"experiencedDate":"2024-12-22T00:00:00.000Z","publishedDate":"2024-12-23T00:32:38.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"659446228114f00012ffe641","displayName":"Grey Seymour","imageUrl":"","numberOfReviews":2,"countryCode":"US","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":2,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"en","location":null},{"id":"60370c55f85d7509d8e3ae4e","filtered":false,"pending":false,"text":"Worst app ever would give 0 stars if I could , deposited money with fortmatic doesn’t allow me to send or withdraw my money says I have no assets but shows my balance . Scam avoid at all cost !!!!!","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2021-02-25T02:32:53.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Worst app ever would give 0 stars if I…","likes":0,"source":"Organic","dates":{"experiencedDate":null,"publishedDate":"2021-02-25T02:32:53.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"60370c4cd8cdec001ad3ae46","displayName":"Xxx ","imageUrl":"","numberOfReviews":2,"countryCode":"GB","hasImage":false,"isVerified":false},"reply":{"message":"Hi there, thank you for leaving your review!\n\nPlease note that Zerion neither has its own wallet nor has access to your funds as we are a non-custodial interface.\n\nWe'd love to look into this \u0026 help you out. To send out funds from your Fortmatic wallet, simply connect it to http://app.zerion.io/ \u0026 click on 'Send'.\n\nIf you have any questions or feedback here, please reach out to inbox@zerion.io for further assistance.\n\nWe hope you consider updating your review if our app meets your standards! ","publishedDate":"2021-04-19T18:40:35.443Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"en","location":null},{"id":"5e969d86086b6409bc84a920","filtered":false,"pending":false,"text":"Most helpful crypto portfolio dashboard ever!  Excellent team behind it, a very helpful community manager too (look for Abi).\nYou can track your portfolio earnings within 24hrs, you can also check the price right on the dashboard too. If you want to add liquidity to a pool, they provide Uniswap and Bancor pool. You can also lend your stablecoins directly on the dasboard, that means you can also borrow coins too! They have an exchange feature available, so you can trade instantly!","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2020-04-15T05:37:10.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":null,"hasDachExclusion":false}},"title":"Excellent product, great community and dev, more features incoming","likes":0,"source":"BasicLink","dates":{"experiencedDate":null,"publishedDate":"2020-04-15T05:37:10.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"5e969d72e638eb188dcd8742","displayName":"Intervenant Aion","imageUrl":"","numberOfReviews":1,"countryCode":"ID","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"en","location":null},{"id":"61a7f1d92b49257fe29193df","filtered":false,"pending":false,"text":"Best Ethereum-based portfolio manager around. Not only can you track balances across wallets and L2s but also you can \"swap\" tokens for LP tokens (eg uniswap LP) or vaults (yearn) and their backend figures out how to do it. \n\nThe iPhone app has cool widgets like a portfolio tracker for your Home Screen or a gas tracker","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2021-12-01T22:06:17.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Best Ethereum-based portfolio manager…","likes":0,"source":"Organic","dates":{"experiencedDate":null,"publishedDate":"2021-12-01T22:06:17.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"61a7f1d1aa83ea001248ac16","displayName":"Oscar RA","imageUrl":"","numberOfReviews":1,"countryCode":"MX","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"en","location":null}],"products":null,"filters":{"hasActiveFilters":false,"totalNumberOfReviews":159,"totalNumberOfFilteredReviews":153,"pagination":{"currentPage":1,"perPage":20,"totalCount":153,"totalPages":8},"selected":{"languages":"en","date":null,"stars":null,"aspects":null,"topics":null,"search":null,"locationId":null,"sort":"recency","verified":false,"replies":false},"reviewStatistics":{"hasMultipleLanguages":true,"reviewLanguages":[{"isoCode":"all","reviewCount":159,"displayName":"all"},{"isoCode":"de","reviewCount":1,"displayName":"Deutsch"},{"isoCode":"en","reviewCount":153,"displayName":"English"},{"isoCode":"fr","reviewCount":3,"displayName":"français"},{"isoCode":"nl","reviewCount":1,"displayName":"Nederlands"},{"isoCode":"zh","reviewCount":1,"displayName":"中文"}],"rati